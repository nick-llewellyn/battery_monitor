# Dart / Flutter
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
build/
pubspec.lock

# CocoaPods (regenerated by `pod install`)
example/ios/Podfile.lock
example/macos/Podfile.lock
example/ios/Pods/
example/macos/Pods/

# Swift Package Manager build artefacts
.build/
.swiftpm/

# IDE -- JetBrains
.idea/
*.iml
*.ipr
*.iws

# IDE -- VS Code workspace files (machine-specific)
.vscode/

# FVM Version Cache (machine-specific symlink + downloaded SDK)
.fvm/

# macOS Finder metadata
.DS_Store

# Coverage reports
coverage/

# Local AI agent memory (beads issue DB + Claude Code settings).
# Per-developer state, not part of the published package surface.
.beads/
.claude/
.dolt/
*.db
.beads-credential-key
