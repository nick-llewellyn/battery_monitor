# Dart / Flutter
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
build/
pubspec.lock

# Generated freezed sources are regenerated locally via
# `dart run build_runner build`. They are committed so that consumers
# pulling the package via path: dependency or git ref do not need the
# code generator installed. CI re-runs the build to assert no drift.
# (No ignore entry here -- listed for clarity.)

# CocoaPods (regenerated by `pod install`)
example/ios/Podfile.lock
example/macos/Podfile.lock
example/ios/Pods/
example/macos/Pods/

# IDE -- JetBrains
.idea/
*.iml
*.ipr
*.iws

# IDE -- VS Code workspace files (machine-specific)
.vscode/

# FVM Version Cache (machine-specific symlink + downloaded SDK)
.fvm/

# macOS Finder metadata
.DS_Store

# Coverage reports
coverage/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
